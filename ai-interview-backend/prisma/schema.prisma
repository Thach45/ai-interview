generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ================= ENUMS (CÁC KIỂU DỮ LIỆU CỐ ĐỊNH) =================

enum Role {
  CANDIDATE 
  MODERATOR     
  ADMIN     
}

enum SessionStatus {
  PENDING       
  IN_PROGRESS   
  EVALUATING    
  COMPLETED     
  FAILED        
}

enum MessageRole {
  AI
  USER
}

enum PaymentStatus {
  PENDING   // Đang chờ quét QR / chuyển khoản
  SUCCESS   // Tiền đã vào tài khoản
  FAILED    // Giao dịch lỗi / hủy
}

enum ExperienceLevel {
  INTERN
  FRESHER
  JUNIOR
  MIDDLE
  SENIOR
  MANAGER
  DIRECTOR
}

enum Provider {
  GOOGLE
  LOCAL
}

enum CategoryType {
  GROUP      // Nhóm nghề (Cấp 1)
  INDUSTRY   // Nghề (Cấp 2)
  POSITION   // Vị trí chuyên môn (Cấp 3)
}
enum UserStatus {
  ACTIVE
  INACTIVE
}


// ================= THỰC THỂ CỐT LÕI (CORE ENTITIES) =================

// 1. BẢNG NGƯỜI DÙNG
model User {
  id               String           @id @default(auto()) @map("_id") @db.ObjectId
  email            String           @unique
  fullName         String
  avatarUrl        String?          
  role             Role             @default(CANDIDATE)
  password         String?
  provider         Provider         @default(LOCAL)
  googleId         String?          
  status           UserStatus       @default(ACTIVE)
  emailVerifiedAt   DateTime?
  creditsBalance   Int              @default(3) // Tặng 3 lượt test free ban đầu

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Quan hệ
  cvs              UserCv[]
  sessions         InterviewSession[]
  cvAnalyses       CvAnalysis[]
  recruiterRooms   RecruiterRoom[]  
  transactions     Transaction[]
}

// 2. BẢNG HỒ SƠ CV
model UserCv {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  userId           String   @db.ObjectId
  title            String   
  fileUrl          String   
  contentExtracted String   // MongoDB tự hiểu chuỗi dài, không cần @db.Text
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions         InterviewSession[]
  analyses         CvAnalysis[]
}

// 3. BẢNG DANH MỤC PHÂN CẤP (Nhóm nghề -> Nghề -> Vị trí)
model JobCategory {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  type        CategoryType
  
  parentId    String?        @db.ObjectId
  parent      JobCategory?   @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    JobCategory[]  @relation("CategoryHierarchy")

  jobTemplates JobTemplate[]
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// 4. BẢNG JOB TEMPLATE (Đã tách 3 phần tối ưu)
model JobTemplate {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  title              String
  companyName        String
  companyLogo        String?
  
  // Thông tin cơ bản
  location           String?  
  salaryRange        String?  
  employmentType     String?  
  experienceLevel    ExperienceLevel @default(JUNIOR)
  isRemote           Boolean         @default(false)
  
  // Phân loại
  categoryId         String?         @db.ObjectId
  category           JobCategory?    @relation(fields: [categoryId], references: [id])
  
  // Thông tin chi tiết để render UI
  responsibilities   String   
  requirements       String   
  benefits           String   
  
  // Thông tin cốt lõi cho AI đọc
  aiExtractedContext String   
  
  isHotJob           Boolean  @default(false) 
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sessions           InterviewSession[]
  cvAnalyses         CvAnalysis[]
}


// ================= THỰC THỂ AI INTERVIEW & GIAO DỊCH =================

// 4. BẢNG PHIÊN PHỎNG VẤN
model InterviewSession {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  userId           String        @db.ObjectId
  status           SessionStatus @default(PENDING)

  jobTemplateId    String?       @db.ObjectId
  customJdText     String?       
  
  cvId             String?       @db.ObjectId
  recruiterRoomId  String?       @db.ObjectId

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cv               UserCv?        @relation(fields: [cvId], references: [id])
  jobTemplate      JobTemplate?   @relation(fields: [jobTemplateId], references: [id])
  recruiterRoom    RecruiterRoom? @relation(fields: [recruiterRoomId], references: [id])
  
  messages         InterviewMessage[]
  result           InterviewResult?   
}

// 5. BẢNG LỊCH SỬ CHAT
model InterviewMessage {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  sessionId        String      @db.ObjectId
  role             MessageRole 
  content          String      
  audioUrl         String?     
  
  createdAt        DateTime    @default(now())

  session          InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId]) 
}

// 6. BẢNG BÁO CÁO KẾT QUẢ
model InterviewResult {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionId        String   @unique @db.ObjectId
  
  overallScore     Int
  clarityScore     Int      
  confidenceScore  Int      
  relevanceScore   Int      

  feedbackJson     Json
  
  createdAt        DateTime @default(now())

  session          InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum TransactionType {
  DEPOSIT       // Nạp tiền từ cổng thanh toán
  COMPENSATION  // Đền bù từ hệ thống
  PROMOTION     // Khuyến mãi, quà tặng
}

// 7. BẢNG LỊCH SỬ NẠP TIỀN (Pay-as-you-go)
model Transaction {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  userId        String          @db.ObjectId
  type          TransactionType @default(DEPOSIT)
  
  amount        Int           // Số tiền nạp
  creditsAdded  Int           // Số credit tương ứng
  status        PaymentStatus @default(PENDING) 
  paymentRefId  String?       @unique // Mã đối soát của VNPay/Momo
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ================= THỰC THỂ TÍNH NĂNG PHỤ TRỢ =================

// Enum cho mức độ ưu tiên của gợi ý
enum AnalysisPriority {
  HIGH
  MEDIUM
  LOW
}

// Enum cho các hạng mục chấm điểm
enum ScoreCategory {
  TECHNICAL_SKILLS
  EXPERIENCE
  SOFT_SKILLS
  EDUCATION
  PROJECT_RELEVANCE
}

// Định nghĩa cấu trúc cho phân tích kỹ năng
type SkillAnalysis {
  skill    String
  user     Int
  required Int
}

// Định nghĩa cấu trúc cho gợi ý cải thiện
type ImprovementSuggestion {
  title    String
  desc     String
  solution String
  priority AnalysisPriority
}

// Định nghĩa cấu trúc cho chi tiết điểm số kèm lý do
type ScoreDetail {
  category ScoreCategory
  score    Int
  reason   String
}

// 8. BẢNG PHÂN TÍCH CV (Trợ lý ứng tuyển)
model CvAnalysis {
  id                     String                  @id @default(auto()) @map("_id") @db.ObjectId
  userId                 String                  @db.ObjectId
  cvId                   String                  @db.ObjectId
  jobTemplateId          String                  @db.ObjectId
  
  matchScore             Int      
  summary                String?
  
  // Chi tiết điểm số theo từng hạng mục
  scoringDetails         ScoreDetail[]
  
  strengths              String[]
  weaknesses             String[]
  skillsAnalysis         SkillAnalysis[]
  foundKeywords          String[]
  missingKeywords        String[]
  improvementSuggestions ImprovementSuggestion[]
  
  createdAt              DateTime @default(now())

  user                   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cv                     UserCv      @relation(fields: [cvId], references: [id], onDelete: Cascade)
  jobTemplate            JobTemplate @relation(fields: [jobTemplateId], references: [id], onDelete: Cascade)
}

// 9. BẢNG PHÒNG TUYỂN DỤNG (Recruiter Mode)
model RecruiterRoom {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  hrId             String   @db.ObjectId
  roomName         String   
  jdContext        String   
  
  invitationToken  String   @unique @default(uuid()) 
  isActive         Boolean  @default(true)
  expiresAt        DateTime? 
  
  createdAt        DateTime @default(now())

  hr               User               @relation(fields: [hrId], references: [id], onDelete: Cascade)
  sessions         InterviewSession[] 
}
// 10. BẢNG MÃ XÁC THỰC (OTP)
model VerificationCode {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}
